{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rangeStrategy": "auto",
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "commitMessagePrefix": "deps:",
{
  "regexManagers": [
    {
      "fileMatch": ["(^|/)deno\\.json$"],
      "matchStrings": [
        "\"npm:(?<depName>[^@]+)@(?<currentValue>[^\\\"]+)\""
      ],
      "datasourceTemplate": "npm"
    }
  ]
}
