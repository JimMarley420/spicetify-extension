{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rangeStrategy": "auto",
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "commitMessagePrefix": "deps:",
  "regexManagers": [
    {
      "description": "Detect Deno imports in deno.json",
      "fileMatch": ["(^|/)deno\\.json$"],
      "matchStrings": [
        "\"(?<depName>[^\"@/]+)@(?<currentValue>[^\"@]+)\""
      ],
      "datasourceTemplate": "deno"
    }
  ]
}
