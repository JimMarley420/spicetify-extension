{
  "tasks": {
    "release": "deno run -A tasks/release.ts",
    "dev-build": "deno run -A tasks/build.ts --dev",
    "build": "deno run -A tasks/build.ts",
    "concat": "deno run -A tasks/concat.ts",
    "dev-watch": "deno run -A tasks/watch.ts --dev",
    "watch": "deno run -A tasks/watch.ts",
    "lint": "deno run -A @biomejs/biome check",
    "typecheck": "deno check tasks/build.ts tasks/pluginInlineCSS.ts tasks/reactCompilerPlugin.ts tasks/release.ts tasks/spicetifyShimsPlugin.ts shared/api/ shared/utils/ shared/webpack/",
    "test": "deno test --allow-all",
    "check": "deno task lint && deno task typecheck",
    "format": "deno run -A @biomejs/biome format --write"
  },
  "imports": {
    "@biomejs/biome": "npm:@biomejs/biome@2.4.4",
    "@esbuild/": "https://deno.land/x/esbuild@v0.27.2/",
    "@oazmi/esbuild-plugin-deno": "jsr:@oazmi/esbuild-plugin-deno@0.4.5",
    "@std/bytes": "jsr:@std/bytes@1.0.11",
    "@std/path": "jsr:@std/path@1.1.4",
    "@std/streams": "jsr:@std/streams@1.0.17",
    "esbuild-plugin-babel": "npm:esbuild-plugin-babel@^0.2.3",
    "react": "https://esm.sh/react@19.2.3",
    "react-dom": "https://esm.sh/react-dom@19.2.3",
    "react-dom/client": "https://esm.sh/react-dom@19.2.3/client",
    "react/jsx-runtime": "https://esm.sh/react@19.2.3/jsx-runtime",
    "babel-plugin-react-compiler": "npm:babel-plugin-react-compiler@latest",
    "@babel/preset-typescript": "npm:@babel/preset-typescript@latest",
    "@babel/preset-react": "npm:@babel/preset-react@latest",
    "react-compiler-runtime": "npm:react-compiler-runtime@latest",
    "@babel/core": "npm:@babel/core@latest"
  },
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable", "dom.asynciterable", "deno.ns", "deno.unstable"],
    "jsx": "react-jsx",
    "strict": true
  },
  "nodeModulesDir": "auto",
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["dist/", "node_modules/"]
  }
}